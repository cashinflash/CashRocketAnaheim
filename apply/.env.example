# Cash Rocket Anaheim — apply.cashrocketanaheim.com
# Copy these values from your existing cif-apply Render service env vars so
# both apply backends write to the SAME Firebase / Plaid / Claude setup.
# Every row below must be set in your new Render service before first deploy.

# --- Plaid ---
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=production

# --- Claude (Anthropic) API ---
ANTHROPIC_API_KEY=

# --- Firebase (service account credentials) ---
# Same project as cif-apply so submissions land in the same DB the dashboard
# reads from. Paste the JSON credentials as a single-line string, or the
# individual keys depending on how cif-apply currently sets this.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# (Or FIREBASE_CREDENTIALS_JSON if that's the pattern cif-apply uses.)

# --- Notification webhooks / SMTP (if used by cif-apply) ---
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
# NOTIFY_EMAIL=

# --- Server ---
PORT=10000  # Render sets this automatically; leave default.
